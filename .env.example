# ─────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:4200
ALLOWED_ORIGINS=http://localhost:4200
ENVIRONMENT=development

# ─────────────────────────────────────────────
# JWT / Tokens
# ─────────────────────────────────────────────
JWT_TOKEN_SECRET=change-me-to-a-long-random-secret
ACCESS_TOKEN_EXPIRATION=15m
REFRESH_TOKEN_EXPIRATION=7d
SECURITY_TOKEN_EXPIRATION=24h

# ─────────────────────────────────────────────
# Tenant Manager Database  (public schema)
# ─────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=postgres
DB_NAME=tenant_manager
DB_LOGGING=false

# ─────────────────────────────────────────────
# Multi-tenancy
#   MULTI_SCHEMA=true  → resolve tenant from tenant_id header
#   MULTI_SCHEMA=false → use the single-tenant vars below
# ─────────────────────────────────────────────
MULTI_SCHEMA=false

# Single-tenant fallback (only used when MULTI_SCHEMA=false)
TENANT_ID=00000000-0000-0000-0000-000000000001
TENANT_NAME=Default
TENANT_SLUG=default
TENANT_URL=http://localhost:4200

# ─────────────────────────────────────────────
# Application (Tenant) Database
# ─────────────────────────────────────────────
TENANT_DB_HOST=localhost
TENANT_DB_PORT=5432
TENANT_DB_USER=postgres
TENANT_DB_PASS=postgres
TENANT_DB_NAME=app_db
TENANT_DB_SCHEMA=default

# ─────────────────────────────────────────────
# Rate Limiting
# ─────────────────────────────────────────────
THROTTLER_TTL=60000
THROTTLER_LIMIT=10

# ─────────────────────────────────────────────
# Mail (SMTP)
# ─────────────────────────────────────────────
MAIL_FROM=no-reply@example.com
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USER=smtp-user
MAIL_PASS=smtp-password
# Optional: override recipient for all emails (useful in development)
# MAIL_TO=dev@example.com

# ─────────────────────────────────────────────
# Login Security  (all optional – shown with defaults)
# ─────────────────────────────────────────────
# LOGIN_MAX_ATTEMPTS=5
# LOGIN_LOCKOUT_MINUTES=15
# REQUIRE_EMAIL_CONFIRMATION=false

# ─────────────────────────────────────────────
# Redis  (ready to wire — not yet consumed by app)
# ─────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASS=redis_secret

# ─────────────────────────────────────────────
# OpenTelemetry
#   OTEL_ENABLED=false  → completely disabled (default, zero overhead)
#   OTEL_ENABLED=true   → traces + metrics sent to OTEL_EXPORTER_OTLP_ENDPOINT
# ─────────────────────────────────────────────
OTEL_ENABLED=false
OTEL_SERVICE_NAME=nest-app
# OTLP HTTP endpoint (OpenTelemetry Collector, Datadog Agent, etc.)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# Comma-separated key=value pairs forwarded as HTTP headers to the exporter
# Examples:
#   Datadog:     OTEL_EXPORTER_OTLP_HEADERS=DD-API-KEY=<api-key>
#   New Relic:   OTEL_EXPORTER_OTLP_HEADERS=api-key=<license-key>
#   Grafana:     OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic <base64>
# OTEL_EXPORTER_OTLP_HEADERS=
# Metrics export interval in milliseconds (default 30 s)
# OTEL_METRIC_EXPORT_INTERVAL=30000

# ─────────────────────────────────────────────
# Backend APM credentials (used only by otel-collector-config.yaml)
# These are passed to the OTel Collector container via docker-compose.yaml
# and referenced as ${VAR_NAME} inside the collector config.
# ─────────────────────────────────────────────
# DATADOG_API_KEY=
# NEW_RELIC_LICENSE_KEY=
# ELASTIC_APM_SECRET_TOKEN=
# GRAFANA_CLOUD_TOKEN=
# HONEYCOMB_API_KEY=
