{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "builder": "swc",
    "typeCheck": true,
    "deleteOutDir": true,
    "assets": [
      {
        "include": "shared/infra/email/templates/**/*",
        "watchAssets": true
      },
      {
        "include": "shared/infra/database/typeorm/application/migrations/scripts/*",
        "watchAssets": true
      }
    ]
  }
}
