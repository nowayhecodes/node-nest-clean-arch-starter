{
  "compilerOptions": {
    "module": "commonjs",
    "strictNullChecks": true,
    "strictPropertyInitialization": false,
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "target": "ES2021",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": ".",
    "moduleResolution": "node",
    "incremental": false,
    "skipLibCheck": true,
    "paths": {
      "~/*": ["src/*"],
      "~/test/*": ["test/*"]
    }
  }
}
