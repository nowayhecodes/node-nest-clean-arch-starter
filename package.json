{
  "name": "node-nest-clean-arch-starter",
  "version": "1.0.0",
  "description": "",
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=24.x"
  },
  "scripts": {
    "build": "nest build",
    "format": "prettier --write .",
    "start": "nest start -b swc",
    "start:dev": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "pre-commit": "lint-staged",
    "prepare": "husky",
    "test": "NODE_ENV=test jest",
    "migration:run": "tsx ./src/shared/infra/database/typeorm/migrations/typeorm-migration.script.ts",
    "migration:revert": "tsx ./src/shared/infra/database/typeorm/migrations/typeorm-revert-migration.script.ts",
    "model:generate": "npx typeorm-model-generator -h localhost -d example_db -u postgres -x postgres -e postgres -s localdatabase",
    "migration:drop": "tsx ./src/shared/infra/database/typeorm/migrations/typeorm-clear-all.script.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/helmet": "^13.0.2",
    "@nestjs/common": "11.1.19",
    "@nestjs/config": "4.0.4",
    "@nestjs/core": "11.1.19",
    "@nestjs/event-emitter": "3.1.0",
    "@nestjs/jwt": "11.0.2",
    "@nestjs/passport": "11.0.5",
    "@nestjs/platform-fastify": "11.1.19",
    "@nestjs/swagger": "11.4.2",
    "@nestjs/throttler": "6.5.0",
    "@opentelemetry/auto-instrumentations-node": "^0.75.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.217.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.217.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-node": "^0.217.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@swc/cli": "0.8.1",
    "@swc/core": "1.15.33",
    "@swc/jest": "0.2.39",
    "class-transformer": "0.5.1",
    "class-validator": "0.15.1",
    "dotenv": "17.4.2",
    "fastify": "5.8.5",
    "jsonwebtoken": "9.0.3",
    "mjml": "5.1.0",
    "nodemailer": "8.0.7",
    "passport": "0.7.0",
    "passport-custom": "1.1.1",
    "pg": "8.20.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "typeorm": "0.3.28",
    "typeorm-model-generator": "0.4.6"
  },
  "devDependencies": {
    "@commitlint/cli": "19.5.0",
    "@commitlint/config-conventional": "19.5.0",
    "@faker-js/faker": "10.4.0",
    "@nestjs/cli": "11.0.21",
    "@nestjs/schematics": "11.1.0",
    "@nestjs/testing": "11.1.19",
    "@semantic-release/commit-analyzer": "13.0.0",
    "@semantic-release/git": "10.0.1",
    "@semantic-release/github": "11.0.0",
    "@semantic-release/npm": "12.0.1",
    "@semantic-release/release-notes-generator": "14.0.1",
    "@types/jest": "30.0.0",
    "@types/mjml": "5.0.0",
    "@types/node": "25.6.0",
    "husky": "9.1.7",
    "jest": "30.3.0",
    "jest-mock-extended": "4.0.1",
    "lint-staged": "16.4.0",
    "prettier": "3.5.3",
    "semantic-release": "25.0.3",
    "source-map-support": "0.5.21",
    "tsx": "4.21.0",
    "typescript": "6.0.3"
  },
  "release": {
    "branches": [
      {
        "name": "main"
      }
    ],
    "repositoryUrl": "https://github.com/nowayhecodes/node-nest-clean-arch-starter",
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      [
        "@semantic-release/npm",
        {
          "npmPublish": false
        }
      ],
      [
        "@semantic-release/git",
        {
          "message": "chore(release): ${nextRelease.version} \n\n${nextRelease.notes}"
        }
      ],
      "@semantic-release/github"
    ]
  },
  "packageManager": "pnpm@10.5.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@swc/core"
    ],
    "ignoredBuiltDependencies": [
      "@scarf/scarf",
      "esbuild",
      "sqlite3",
      "unrs-resolver"
    ]
  }
}
